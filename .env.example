HOST=localhost
PORT=5000

JWT_SECRET=your-secret-key-here
JWT_ISSUER=pibot
JWT_ACCESS_TTL_MIN=1440

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=disable

# Wallet mnemonic encryption key — generate with: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=seZiFyGljomD3J0uBpU0MsqC2T1hP1ck3uNz8dwx7jI=

# Outbound proxy for all Horizon/Stellar RPC requests (hides server IP)
# Supports HTTP, HTTPS, and SOCKS5 proxies. Leave unset to connect directly.
# PROXY_URL=http://user:pass@proxy.example.com:8080
# PROXY_URL=socks5://user:pass@proxy.example.com:1080
